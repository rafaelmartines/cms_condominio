{
    "name":"cms_condominio",
    "version":"1.0.0",
    "author":"You",
    "location":"forgeboxStorage",
    "slug":"cmscondominio",
    "createPackageDirectory":false,
    "type":"mvc",
    "keywords":"",
    "homepage":"",
    "documentation":"",
    "repository":{
        "type":"",
        "url":""
    },
    "bugs":"",
    "shortDescription":"",
    "contributors":[],
    "ignore":[],
    "devDependencies":{
        "testbox":"*",
        "commandbox-boxlang":"*"
    },
    "dependencies":{
        "coldbox":"8.1.0+34",
        "quick":"^12.0.12",
        "cbpaginator":"^2.8.3"
    },
    "installPaths":{
        "coldbox":"lib/coldbox/",
        "testbox":"lib/testbox/",
        "quick":"modules/quick/",
        "cbpaginator":"modules/cbpaginator/"
    },
    "scripts":{
        "format":"!boxlang format --source config/,handlers/,interceptors/,models/,modules_app/,tests/specs/,*.cfc",
        "format:check":"!boxlang format --check --source config/,handlers/,interceptors/,models/,modules_app/,tests/specs/,*.cfc",
        "docker:build":"!docker build --no-cache -t my-coldbox-app -f ./docker/Dockerfile ./",
        "docker:run":"!docker run -it -p 8080:8080 my-coldbox-app",
        "docker:bash":"!docker run -it my-coldbox-app /bin/bash",
        "docker:stack":"!docker compose -f docker/docker-compose.yaml ${1}"
    },
    "testbox":{
        "runner":"/tests/runner.cfm"
    },
    "language":"CFML",
    "description":"A ColdBox Application created with the ColdBox CLI"
}
